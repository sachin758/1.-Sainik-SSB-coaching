# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL) — either use DATABASE_URL (Render/Railway give you this)
# or fill in the individual PG_* fields below.
DATABASE_URL=postgres://username:password@localhost:5432/gvc_academy
PGSSL=false

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=1d

# First admin account (created automatically on first migrate run if no admin exists)
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@gvcacademy.in
SEED_ADMIN_PASSWORD=change_this_password

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5500
